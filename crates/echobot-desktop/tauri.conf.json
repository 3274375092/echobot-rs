{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EchoBot",
  "version": "0.1.0",
  "identifier": "local.echobot.desktop",
  "build": {
    "frontendDist": "./web-stub"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "EchoBot",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
